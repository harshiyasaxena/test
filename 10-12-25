def mark_missing_PN_red_for_desc(PN_set, expected_dsi_list, sheet3, error_msg, normalize_fn=normalize_PN):
    """
    PN_set: iterable of PN values that we expect (keys from PN_to_desc)
    expected_dsi_list: list or set of DSI strings we expect for these PNs (e.g. ["PF"])
    sheet3: worksheet 'Report Data'
    """
    red_fill = PatternFill(start_color="FF0000", end_color="FF0000", fill_type="solid")

    # Build map: normalized_part -> set of DSIs present anywhere for that part
    part_dsis = {}
    for row in sheet3.iter_rows(min_row=2):
        part_cell = row[9].value  # Part No column (index 9 in your code)
        dsi_cell = row[12].value  # DSI column (index 12 in your code)
        if part_cell:
            p = normalize_fn(part_cell)
            dsi = (str(dsi_cell).strip().upper() if dsi_cell else "")
            part_dsis.setdefault(p, set()).add(dsi)

    expected_dsis_upper = {s.strip().upper() for s in expected_dsi_list}

    # For each PN we expect, check if ANY occurrence has any of expected DSIs.
    for PN_val in PN_set:
        norm_PN = normalize_fn(PN_val)
        dsis_for_part = part_dsis.get(norm_PN, set())
        found_match = any(d in dsis_for_part for d in expected_dsis_upper if d)

        if not found_match:
            # No occurrence had the expected DSI -> mark all rows for that PN red and add comment
            for row in sheet3.iter_rows(min_row=2):
                cell_part = row[9].value
                if not cell_part:
                    continue
                if normalize_fn(cell_part) == norm_PN:
                    # color the Part No cell red and add comment
                    row[9].fill = red_fill
                    add_error_comment_to_PN_cell(sheet3, PN_val, error_msg)
