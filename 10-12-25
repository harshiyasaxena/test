```python
def compare_and_color(sheet3, PN_to_desc, dsi_match, error_msg_unmatched, normalize_fn=normalize_PN):
    """
    For each row in sheet3: if the row's DSI == dsi_match and the Part No exists in PN_to_desc,
    compare nomen vs expected description and color that row green or red accordingly.
    Do NOT mark other occurrences of the same Part No that don't carry the dsi_match.
    """
    green_fill = PatternFill(start_color="00FF00", end_color="00FF00", fill_type="solid")
    red_fill   = PatternFill(start_color="FF0000", end_color="FF0000", fill_type="solid")

    dsi_match_up = dsi_match.strip().upper()

    # iterate rows and handle only rows whose DSI equals the desired DSI
    last_part_no = None
    for row in sheet3.iter_rows(min_row=2):
        if row[9].value:
            last_part_no = normalize_fn(row[9].value)
        if not last_part_no:
            continue

        # get this row's DSI and nomen
        dsi_val = (str(row[12].value).strip().upper() if row[12].value else "")
        if dsi_val != dsi_match_up:
            # this row doesn't carry the DSI we're checking — skip coloring here
            continue

        # lookup expected description for this PN (PN_to_desc keys are in sheet2 format)
        expected_desc = PN_to_desc.get(last_part_no) or PN_to_desc.get(row[9].value) or None
        nomen_val = (str(row[11].value).strip() if row[11].value else "")

        if expected_desc is None:
            # no expected description found for this PN — mark row red and comment
            for cell in row:
                cell.fill = red_fill
            add_error_comment_to_PN_cell(sheet3, row[9].value, f"No expected description found for DSI {dsi_match}")
            continue

        # normalize both sides depending on DSI type (you used different logic earlier)
        if dsi_match_up in ("PF", "MD", "QDQ"):
            left = normalize(nomen_val)
            right = normalize(expected_desc)
        else:
            left = normalize_PN(nomen_val)
            right = normalize_PN(expected_desc)

        if left == right:
            # match -> color only the two relevant cells (Nomenclature & DSI) green
            try:
                row[11].fill = green_fill
                row[12].fill = green_fill
            except Exception:
                pass
        else:
            try:
                row[11].fill = red_fill
                row[12].fill = red_fill
            except Exception:
                pass
            add_error_comment_to_PN_cell(sheet3, row[9].value, error_msg_unmatched)
