def check_dsi_per_instance(sheet, pn_requirements_dict, target_dsi_list, error_msg, normalize_fn, exempt_dsi_list=None):
    from openpyxl.styles import PatternFill
    from openpyxl.comments import Comment

    red_fill = PatternFill(start_color="FF0000", end_color="FF0000", fill_type="solid")
    
    # Variables to hold the current block's data
    current_pn_val = None
    current_pn_cell = None
    current_block_rows = []

    # Helper to process a finished block
    def process_block(pn_val, pn_cell, rows):
        if not pn_val: return

        # Normalize key for dictionary lookup
        norm_pn = normalize_fn(pn_val)
        
        # 1. Check if this PN exists in our Requirements (from Sheet 2)
        # If the PN is not in Sheet 2, we skip checking it.
        if norm_pn not in pn_requirements_dict:
            return 

        # 2. Check if the Target DSI exists in THIS specific block
        found_target = False
        
        for r in rows:
            # Column 13 is Index 12 (DSI)
            dsi_val = str(r[12].value).strip() if r[12].value else ""
            
            # Check for target (e.g., "PF")
            if dsi_val in target_dsi_list:
                found_target = True
            
            # Check for exempt codes (e.g., "CD") if provided
            if exempt_dsi_list and dsi_val in exempt_dsi_list:
                # If we find an exempt code, we consider this block valid (or "found")
                found_target = True 

        # 3. If missing, mark ONLY this specific cell
        if not found_target:
            # Apply Red Fill
            pn_cell.fill = red_fill
            
            # Apply Comment Manually (Do NOT use the global helper function)
            existing_comment = pn_cell.comment
            new_text = error_msg
            
            if existing_comment:
                if new_text not in existing_comment.text:
                    new_text = existing_comment.text + "\n" + new_text
                else:
                    new_text = existing_comment.text
            
            pn_cell.comment = Comment(new_text, author="System")

    # Iterate through rows starting from row 2
    for row in sheet.iter_rows(min_row=2):
        pn_cell = row[9] # Column J (Part Number)
        val = pn_cell.value
        
        # If we find a value in Part Number column, it's the start of a new block
        if val:
            # Process the PREVIOUS block before starting the new one
            if current_pn_val is not None:
                process_block(current_pn_val, current_pn_cell, current_block_rows)
            
            # Start tracking new block
            current_pn_val = str(val).strip()
            current_pn_cell = pn_cell
            current_block_rows = [row] # Start list with header row
        else:
            # It's a continuation row (Blank PN), add to current block
            if current_pn_val is not None:
                current_block_rows.append(row)

    # Don't forget the very last block in the file
    if current_pn_val is not None:
        process_block(current_pn_val, current_pn_cell, current_block_rows)
```

